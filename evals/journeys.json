            {
              "role": "user",
              "content": "I live in Oaxaca these days.",
              "expectMemories": [
                { "content": "Lives in Oaxaca these days.", "type": "life_event", "keywords": ["city", "live", "oaxaca"], "confidence": 0.85, "importance": 0.8 }
              ]
            },
            { "role": "assistant", "content": "Oaxaca is wonderful." }
          ]
        },
        {
          "sessionId": "s2",
          "eventAt": "2026-06-20T09:00:00.000Z",
          "turns": [
            {
              "role": "user",
              "content": "I live in Lisbon these days.",
              "expectMemories": [
                { "content": "Lives in Lisbon these days.", "type": "life_event", "keywords": ["city", "live", "lisbon"], "confidence": 0.85, "importance": 0.8 }
              ]
            },
            { "role": "assistant", "content": "Lisbon, noted." }
          ]
        }
      ],
      "probes": [
        { "id": "p1", "question": "What city do I live in?", "questionDate": "2026-07-01T10:00:00.000Z", "expect": "answer", "mustContain": ["lisbon"], "dimension": "usefulness" },
        { "id": "p2", "question": "What city do I live in?", "questionDate": "2026-07-01T10:01:00.000Z", "expect": "answer", "mustNotContain": ["oaxaca"], "dimension": "wrong-memory", "knownFinding": "plain re-assertions without correction cues are not auto-superseded; both conflicting facts are briefed with event times" }
      ]
