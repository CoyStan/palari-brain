    {
      "id": "correction-espresso-04",
      "title": "A changed preference supersedes; history is not briefed as current",
      "category": "correction",
      "workspace": { "palariId": "palari-a", "userId": "user-a" },
      "expectTotalWritten": 2,
      "sessions": [
        {
          "sessionId": "s1",
          "eventAt": "2026-05-01T09:00:00.000Z",
          "turns": [
            {
              "role": "user",
              "content": "I prefer a flat white as my espresso drink.",
              "expectMemories": [
                { "content": "Prefers a flat white as the espresso drink.", "type": "preference", "keywords": ["espresso", "drink"], "confidence": 0.9, "importance": 0.7 }
              ]
            },
            { "role": "assistant", "content": "Flat white noted." }
          ]
        },
        {
          "sessionId": "s2",
          "eventAt": "2026-06-15T09:00:00.000Z",
          "turns": [
            {
              "role": "user",
              "content": "Actually I prefer a cortado instead of a flat white as my espresso drink now.",
              "expectMemories": [
                { "content": "Prefers a cortado as the espresso drink.", "type": "preference", "keywords": ["espresso", "drink", "cortado"], "confidence": 0.9, "importance": 0.7 }
              ]
            },
            { "role": "assistant", "content": "Cortado it is." }
          ]
        }
      ],
      "probes": [
        { "id": "p1", "question": "What espresso drink do I prefer?", "questionDate": "2026-07-01T10:00:00.000Z", "expect": "answer", "mustContain": ["cortado"], "mustNotContain": ["flat white"], "dimension": "correction" },
        { "id": "p2", "question": "What espresso drink did I prefer before the cortado?", "questionDate": "2026-07-01T10:02:00.000Z", "expect": "answer", "mustContain": ["flat white"], "dimension": "temporal", "knownFinding": "superseded values are excluded from briefings; as-of temporal recall is a measured gap that temporal-graph engines target" }
      ]
    },
    {
