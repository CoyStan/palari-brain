    {
      "id": "pref-espresso-01",
      "title": "Ordinary preference is remembered across conversations",
      "category": "preference",
      "workspace": { "palariId": "palari-a", "userId": "user-a" },
      "expectTotalWritten": 1,
      "sessions": [
        {
          "sessionId": "s1",
          "eventAt": "2026-05-01T09:00:00.000Z",
          "turns": [
            {
              "role": "user",
              "content": "I prefer a flat white as my espresso drink.",
              "expectMemories": [
                { "content": "Prefers a flat white as the espresso drink.", "type": "preference", "keywords": ["espresso", "drink"], "confidence": 0.9, "importance": 0.7 }
              ]
            },
            { "role": "assistant", "content": "Flat white noted." }
          ]
        }
      ],
      "probes": [
        { "id": "p1", "question": "What espresso drink do I prefer?", "questionDate": "2026-06-01T10:00:00.000Z", "expect": "answer", "mustContain": ["flat white"], "dimension": "usefulness" }
      ]
    },
